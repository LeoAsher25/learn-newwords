# Local: copy to `.env.local`. Production: set in Vercel → Project → Settings → Environment Variables.
NEXT_PUBLIC_APP_NAME=Learn New Words

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# Firebase credentials (priority: FIREBASE_SERVICE_ACCOUNT_JSON > GOOGLE_APPLICATION_CREDENTIALS).
# The former contains the JSON content, while the latter points to a service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
SEED_USER_ID=


APP_BASE_URL=

REMINDER_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=